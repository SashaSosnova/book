rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Планировщик (book / kid-sheduler)
    match /families/{familyCode} {
      allow read, write: if request.auth != null;
    }

    // Tom Sawyer reader — отдельная коллекция, те же правила
    match /tomSawyerFamilies/{familyCode} {
      allow read, write: if request.auth != null;
    }
  }
}
